---
const navItems = [
  { label: "Trabalhos", href: "#trabalhos" },
  { label: "Serviços", href: "#servicos" },
  { label: "Preços", href: "#precos" },
];
---

<nav
  class="fixed inset-x-0 top-0 z-50 flex items-center justify-between px-6 py-5 mix-blend-difference md:px-10"
  aria-label="Navegação principal"
>
  <a href="/" class="nav-link font-mono text-xs tracking-mono no-underline">
    [GL_DG_26]
  </a>

  <div class="hidden items-center gap-5 md:flex">
    {navItems.map((item) => (
      <a
        href={item.href}
        class="nav-link cursor-pointer font-mono text-xs tracking-wider no-underline"
      >
        [{item.label}]
      </a>
    ))}
  </div>

  <a
    href="#contato"
    class="nav-link font-mono text-xs tracking-wider no-underline"
  >
    [Contato]
  </a>
</nav>
