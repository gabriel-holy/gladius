---
interface Props {
  opacity?: number;
}

const { opacity = 0.06 } = Astro.props;
---

<div
  class="pointer-events-none absolute inset-0 overflow-hidden"
  style={`opacity: ${opacity}`}
  aria-hidden="true"
>
  <svg
    class="absolute inset-0 h-full w-full"
    xmlns="http://www.w3.org/2000/svg"
    preserveAspectRatio="xMidYMid slice"
  >
    <defs>
      <!-- Fleur-de-lis (classic heraldic style) -->
      <symbol id="fleur" viewBox="0 0 100 130" overflow="visible">
        <!-- Center petal — tall elegant lily -->
        <path d="
          M50 2
          C52 8, 55 18, 56 28
          C57 38, 56 48, 54 56
          C52 64, 50 68, 50 72
          C50 68, 48 64, 46 56
          C44 48, 43 38, 44 28
          C45 18, 48 8, 50 2Z
        " fill="#F2EDE4"/>
        <!-- Center petal bulb top -->
        <ellipse cx="50" cy="6" rx="5" ry="7" fill="#F2EDE4"/>

        <!-- Left petal — curving outward elegantly -->
        <path d="
          M46 52
          C42 44, 34 36, 26 30
          C20 26, 14 26, 10 30
          C6 34, 4 40, 6 46
          C8 52, 14 56, 22 58
          C30 59, 38 57, 44 54Z
        " fill="#F2EDE4"/>
        <!-- Left petal bulb -->
        <ellipse cx="9" cy="28" rx="6" ry="5" fill="#F2EDE4"/>

        <!-- Right petal — mirror of left -->
        <path d="
          M54 52
          C58 44, 66 36, 74 30
          C80 26, 86 26, 90 30
          C94 34, 96 40, 94 46
          C92 52, 86 56, 78 58
          C70 59, 62 57, 56 54Z
        " fill="#F2EDE4"/>
        <!-- Right petal bulb -->
        <ellipse cx="91" cy="28" rx="6" ry="5" fill="#F2EDE4"/>

        <!-- Horizontal band connecting petals -->
        <rect x="34" y="68" width="32" height="5" rx="2" fill="#F2EDE4"/>

        <!-- Center stem below band -->
        <rect x="44" y="73" width="12" height="24" fill="#F2EDE4"/>

        <!-- Bottom flared base -->
        <path d="
          M44 93 L36 104 L34 108 L66 108 L64 104 L56 93Z
        " fill="#F2EDE4"/>

        <!-- Base plate -->
        <rect x="32" y="108" width="36" height="5" rx="2" fill="#F2EDE4"/>

        <!-- Small cross at very top -->
        <rect x="48" y="0" width="4" height="8" fill="#F2EDE4" opacity="0"/>
      </symbol>

      <!-- Pattern tile with chevron diamonds and fleur-de-lis -->
      <pattern id="classic-pattern" x="0" y="0" width="180" height="220" patternUnits="userSpaceOnUse">
        <!-- Diamond/chevron grid -->
        <!-- Main diamond -->
        <path d="M90 0 L180 110 L90 220 L0 110 Z" fill="none" stroke="#F2EDE4" stroke-width="1.2"/>
        <!-- Neighboring diamonds for seamless tiling -->
        <path d="M-90 0 L0 110 L-90 220" fill="none" stroke="#F2EDE4" stroke-width="1.2"/>
        <path d="M270 0 L180 110 L270 220" fill="none" stroke="#F2EDE4" stroke-width="1.2"/>

        <!-- Inner diamond (thinner) -->
        <path d="M90 18 L166 110 L90 202 L14 110 Z" fill="none" stroke="#F2EDE4" stroke-width="0.5" opacity="0.4"/>

        <!-- Dot rows along chevron diagonals -->
        <!-- Top-left diagonal -->
        <circle cx="18" cy="22" r="2.2" fill="#F2EDE4" opacity="0.5"/>
        <circle cx="30" cy="14" r="2" fill="#F2EDE4" opacity="0.5"/>
        <circle cx="42" cy="8" r="1.8" fill="#F2EDE4" opacity="0.5"/>
        <circle cx="54" cy="4" r="1.6" fill="#F2EDE4" opacity="0.5"/>
        <!-- Top-right diagonal -->
        <circle cx="126" cy="4" r="1.6" fill="#F2EDE4" opacity="0.5"/>
        <circle cx="138" cy="8" r="1.8" fill="#F2EDE4" opacity="0.5"/>
        <circle cx="150" cy="14" r="2" fill="#F2EDE4" opacity="0.5"/>
        <circle cx="162" cy="22" r="2.2" fill="#F2EDE4" opacity="0.5"/>

        <!-- Left-side dots (top to mid) -->
        <circle cx="10" cy="44" r="2" fill="#F2EDE4" opacity="0.5"/>
        <circle cx="6" cy="66" r="2.2" fill="#F2EDE4" opacity="0.5"/>
        <circle cx="4" cy="88" r="2.4" fill="#F2EDE4" opacity="0.5"/>

        <!-- Right-side dots (top to mid) -->
        <circle cx="170" cy="44" r="2" fill="#F2EDE4" opacity="0.5"/>
        <circle cx="174" cy="66" r="2.2" fill="#F2EDE4" opacity="0.5"/>
        <circle cx="176" cy="88" r="2.4" fill="#F2EDE4" opacity="0.5"/>

        <!-- Left-side dots (mid to bottom) -->
        <circle cx="4" cy="132" r="2.4" fill="#F2EDE4" opacity="0.5"/>
        <circle cx="6" cy="154" r="2.2" fill="#F2EDE4" opacity="0.5"/>
        <circle cx="10" cy="176" r="2" fill="#F2EDE4" opacity="0.5"/>

        <!-- Right-side dots (mid to bottom) -->
        <circle cx="176" cy="132" r="2.4" fill="#F2EDE4" opacity="0.5"/>
        <circle cx="174" cy="154" r="2.2" fill="#F2EDE4" opacity="0.5"/>
        <circle cx="170" cy="176" r="2" fill="#F2EDE4" opacity="0.5"/>

        <!-- Bottom-left diagonal -->
        <circle cx="18" cy="198" r="2.2" fill="#F2EDE4" opacity="0.5"/>
        <circle cx="30" cy="206" r="2" fill="#F2EDE4" opacity="0.5"/>
        <circle cx="42" cy="212" r="1.8" fill="#F2EDE4" opacity="0.5"/>
        <circle cx="54" cy="216" r="1.6" fill="#F2EDE4" opacity="0.5"/>
        <!-- Bottom-right diagonal -->
        <circle cx="126" cy="216" r="1.6" fill="#F2EDE4" opacity="0.5"/>
        <circle cx="138" cy="212" r="1.8" fill="#F2EDE4" opacity="0.5"/>
        <circle cx="150" cy="206" r="2" fill="#F2EDE4" opacity="0.5"/>
        <circle cx="162" cy="198" r="2.2" fill="#F2EDE4" opacity="0.5"/>

        <!-- Main fleur-de-lis (centered in diamond) -->
        <use href="#fleur" x="55" y="44" width="70" height="84"/>

        <!-- Small decorative diamonds at intersection points -->
        <rect x="87" y="-3" width="6" height="6" transform="rotate(45 90 0)" fill="#F2EDE4" opacity="0.6"/>
        <rect x="87" y="217" width="6" height="6" transform="rotate(45 90 220)" fill="#F2EDE4" opacity="0.6"/>
        <rect x="-3" y="107" width="6" height="6" transform="rotate(45 0 110)" fill="#F2EDE4" opacity="0.6"/>
        <rect x="177" y="107" width="6" height="6" transform="rotate(45 180 110)" fill="#F2EDE4" opacity="0.6"/>
      </pattern>
    </defs>

    <rect width="100%" height="100%" fill="url(#classic-pattern)"/>
  </svg>

  <!-- Radial vignette -->
  <div
    class="absolute inset-0"
    style="background: radial-gradient(ellipse 60% 55% at 50% 50%, transparent 0%, #070304 100%);"
  />
</div>
