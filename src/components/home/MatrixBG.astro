---
interface Props {
  opacity?: number;
}

const { opacity = 0.06 } = Astro.props;

const chars = "GLADIUSDIGITALWEBDESIGNCODECRIATIVIDADEPIXELAUTOMACAO2026";
const rows = 45;
const cols = 70;
const grid: string[] = [];
for (let r = 0; r < rows; r++) {
  let row = "";
  for (let c = 0; c < cols; c++) {
    row += chars[Math.floor(Math.random() * chars.length)];
  }
  grid.push(row);
}
---

<div
  class="pointer-events-none absolute inset-0 overflow-hidden"
  style={`opacity: ${opacity}`}
  aria-hidden="true"
>
  <pre
    class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 whitespace-pre font-mono text-cream"
    style="font-size: 11px; line-height: 16px; letter-spacing: 3px;"
  >{grid.join("\n")}</pre>

  <!-- Radial vignette -->
  <div
    class="absolute inset-0"
    style="background: radial-gradient(ellipse 60% 55% at 50% 50%, transparent 0%, #070304 100%);"
  />
</div>
