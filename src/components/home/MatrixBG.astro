---
interface Props {
  opacity?: number;
}

const { opacity = 0.06 } = Astro.props;
---

<div
  class="pointer-events-none absolute inset-0 overflow-hidden"
  style={`opacity: ${opacity}`}
  aria-hidden="true"
>
  <!-- Tiled ornamental pattern — grayscale, dark -->
  <div
    class="absolute inset-0"
    style="background: url('/images/tile-pattern.jpg') repeat center center; background-size: 400px 400px; filter: grayscale(1) brightness(0.7) contrast(1.2);"
  />

  <!-- Radial vignette -->
  <div
    class="absolute inset-0"
    style="background: radial-gradient(ellipse 60% 55% at 50% 50%, transparent 0%, #070304 100%);"
  />
</div>
