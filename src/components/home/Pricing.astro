---
interface Plan {
  id: string;
  name: string;
  price: string;
  tagline: string;
  popular?: boolean;
  features: string[];
}

const plans: Plan[] = [
  {
    id: "essencial",
    name: "ESSENCIAL",
    price: "1.497",
    tagline: "Presença digital profissional",
    features: [
      "Landing page de alta conversão",
      "Design responsivo premium",
      "SEO técnico otimizado",
      "Formulário + WhatsApp",
      "Entrega em até 7 dias",
    ],
  },
  {
    id: "profissional",
    name: "PROFISSIONAL",
    price: "2.997",
    tagline: "Para quem quer crescer de verdade",
    popular: true,
    features: [
      "Tudo do Essencial +",
      "Até 5 páginas otimizadas",
      "Funil de captação automatizado",
      "CRM & Email Marketing",
      "Pixel Facebook & Google",
      "Dashboard de métricas",
      "30 dias de suporte",
    ],
  },
  {
    id: "premium",
    name: "PREMIUM",
    price: "4.997",
    tagline: "Solução completa sob medida",
    features: [
      "Tudo do Profissional +",
      "Design ilimitado",
      "Agendamento online",
      "Blog com CMS",
      "Automações avançadas",
      "Treinamento da equipe",
      "60 dias de suporte dedicado",
    ],
  },
];
---

<section id="precos" class="relative bg-cream px-6 py-28 md:px-10">
  <div class="mx-auto max-w-site">
    <div class="mb-20 text-center" data-fade-up>
      <span class="font-mono text-2xs tracking-caps text-vermillion">
        [INVESTIMENTO]
      </span>
      <h2 class="mt-2 font-display text-section-title text-ink">
        TRANSPARENTE. <span class="text-vermillion">SEM SURPRESAS.</span>
      </h2>
    </div>

    <div class="grid grid-cols-1 gap-px bg-ink/10 md:grid-cols-3">
      {plans.map((plan, i) => (
        <div
          class="pricing-card relative flex min-h-[580px] flex-col p-8 md:p-12"
          data-fade-up
          data-delay={String(Math.min(i + 1, 3))}
        >
          {plan.popular && (
            <div class="absolute inset-x-0 top-0 h-[3px] bg-vermillion" />
          )}

          {plan.popular && (
            <span class="mb-5 font-mono text-[9px] tracking-caps text-vermillion">
              [★ MAIS ESCOLHIDO]
            </span>
          )}

          <h3 class="mb-1 font-display text-[32px] tracking-wide text-ink">
            {plan.name}
          </h3>
          <p class="mb-8 font-mono text-xs text-ink/40">
            {plan.tagline}
          </p>

          <div class="mb-9">
            <span class="align-top font-mono text-sm text-ink/40">R$</span>
            <span
              class:list={[
                "ml-1 font-display text-[56px] leading-none tracking-snug",
                plan.popular ? "text-vermillion" : "text-ink",
              ]}
            >
              {plan.price}
            </span>
          </div>

          <div class="mb-9 flex flex-1 flex-col gap-3">
            {plan.features.map((f) => (
              <div class="flex items-start gap-2.5">
                <span class="mt-1 font-mono text-2xs text-vermillion">▸</span>
                <span class="font-mono text-sm leading-relaxed text-ink/50">
                  {f}
                </span>
              </div>
            ))}
          </div>

          <a
            href="#contato"
            class:list={[
              "btn-pricing block w-full cursor-pointer py-4 text-center font-display text-base tracking-widest no-underline",
              plan.popular
                ? "border-none bg-vermillion text-white"
                : "border border-ink/15 bg-transparent text-ink",
            ]}
          >
            COMEÇAR AGORA
          </a>
        </div>
      ))}
    </div>

    <p
      class="mt-7 text-center font-mono text-sm text-ink/30"
      data-fade-up
      data-delay="4"
    >
      Parcelamento em até 12×. Projetos customizados sob consulta.
    </p>
  </div>
</section>
