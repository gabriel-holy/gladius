---
interface Plan {
  id: string;
  name: string;
  price: string;
  tagline: string;
  popular?: boolean;
  features: string[];
}

const plans: Plan[] = [
  {
    id: "essencial",
    name: "ESSENCIAL",
    price: "1.497",
    tagline: "Presença digital profissional",
    features: [
      "Landing page de alta conversão",
      "Design responsivo premium",
      "SEO técnico otimizado",
      "Formulário + WhatsApp",
      "Entrega em até 7 dias",
    ],
  },
  {
    id: "profissional",
    name: "PROFISSIONAL",
    price: "2.997",
    tagline: "Para quem quer crescer de verdade",
    popular: true,
    features: [
      "Tudo do Essencial +",
      "Até 5 páginas otimizadas",
      "Funil de captação automatizado",
      "CRM & Email Marketing",
      "Pixel Facebook & Google",
      "Dashboard de métricas",
      "30 dias de suporte",
    ],
  },
  {
    id: "premium",
    name: "PREMIUM",
    price: "4.997",
    tagline: "Solução completa sob medida",
    features: [
      "Tudo do Profissional +",
      "Design ilimitado",
      "Agendamento online",
      "Blog com CMS",
      "Automações avançadas",
      "Treinamento da equipe",
      "60 dias de suporte dedicado",
    ],
  },
];

const words = [
  { text: "TRANSPARENTE.", color: "ink" },
  { text: "SEM", color: "vermillion" },
  { text: "SURPRESAS.", color: "vermillion" },
];
---

<section id="precos" class="relative bg-cream">

  <!--
    Phase 1: Title reveal runway
    - Cream background, sticky centered title
    - Words reveal one by one from blurred to solid
    - After all revealed, this section ends and cards appear below
  -->
  <div id="pricing-reveal-runway" class="relative">
    <div class="sticky top-0 flex h-screen items-center justify-center px-6 md:px-10">
      <div class="text-center">
        <span
          class="mb-4 block font-mono text-2xs tracking-caps text-vermillion"
          id="pricing-label"
          style="opacity: 0;"
        >
          [INVESTIMENTO]
        </span>

        <h2 class="font-display" style="font-size: clamp(2.8rem, 7vw, 6.5rem); line-height: 1.05;">
          {words.map((word, i) => (
            <span
              class="pricing-word inline"
              data-word-index={i}
              style="opacity: 0.06; filter: blur(6px);"
            >
              <span class={word.color === "vermillion" ? "text-vermillion" : "text-ink"}>
                {word.text}
              </span>
              {i < words.length - 1 && " "}
            </span>
          ))}
        </h2>
      </div>
    </div>
  </div>

  <!--
    Phase 2: Split layout with sticky title left + accordion cards right
    - Title stays sticky on the left (smaller)
    - Cards on right: scroll-driven accordion (open/close one at a time)
  -->
  <div id="pricing-cards-section" class="relative bg-ink" style="opacity: 0; transform: translateY(40px); transition: opacity 0.8s ease, transform 0.8s ease;">
    <div class="mx-auto grid min-h-screen max-w-site grid-cols-1 gap-0 px-6 md:grid-cols-2 md:px-10">

      <!-- LEFT — Sticky title (smaller reprise) -->
      <div class="relative hidden md:block md:pr-16">
        <div class="sticky top-0 flex h-screen flex-col justify-end pb-24 pt-20">
          <span class="mb-4 font-mono text-2xs tracking-caps text-vermillion">
            [INVESTIMENTO]
          </span>
          <h2 class="font-display text-cream" style="font-size: clamp(2rem, 3.5vw, 3.5rem); line-height: 1.1;">
            TRANSPARENTE.<br/>
            <span class="text-vermillion">SEM SURPRESAS.</span>
          </h2>
          <p class="mt-8 max-w-xs font-mono text-sm leading-relaxed text-cream/20">
            Parcelamento em até 12×.<br/>Projetos customizados sob consulta.
          </p>
        </div>
      </div>

      <!-- RIGHT — Accordion cards -->
      <div class="relative py-20 md:py-32">
        <div class="mb-8 font-mono text-sm tracking-wider text-cream/30">
          Nossos planos ↓
        </div>

        {plans.map((plan, i) => (
          <div
            class="pricing-acc mb-4 overflow-hidden rounded-sm transition-all duration-700 ease-[cubic-bezier(0.16,1,0.3,1)]"
            data-plan-index={i}
            style="background: rgba(242,237,228,0.06); border: 1px solid rgba(242,237,228,0.08);"
          >
            <!-- Header — always visible -->
            <div class="flex items-center justify-between px-6 py-5 md:px-8">
              <div class="flex items-center gap-3">
                {plan.popular && (
                  <span class="pricing-acc-badge font-mono text-[9px] tracking-caps text-vermillion transition-opacity duration-500">★</span>
                )}
                <h3 class="pricing-acc-name font-display text-[24px] tracking-wider text-cream/50 transition-all duration-500">
                  {plan.name}
                </h3>
              </div>
              <span class="pricing-acc-price font-display text-[24px] tracking-snug text-cream/20 transition-all duration-500">
                R$ {plan.price}
              </span>
            </div>

            <!-- Body — expands when active -->
            <div
              class="pricing-acc-body transition-all duration-700 ease-[cubic-bezier(0.16,1,0.3,1)]"
              style="max-height: 0; opacity: 0; overflow: hidden;"
            >
              <div class="px-6 pb-8 pt-4 md:px-8">
                <p class="mb-5 font-mono text-xs text-ink/50">
                  {plan.tagline}
                </p>

                <div class="mb-6 flex flex-col gap-3">
                  {plan.features.map((f) => (
                    <div class="flex items-start gap-2.5">
                      <span class="mt-1 font-mono text-2xs text-vermillion">▸</span>
                      <span class="font-mono text-sm leading-relaxed text-ink/60">
                        {f}
                      </span>
                    </div>
                  ))}
                </div>

                <a
                  href="#contato"
                  class:list={[
                    "btn-pricing block w-full cursor-pointer py-4 text-center font-display text-base tracking-widest no-underline",
                    plan.popular
                      ? "border-none bg-vermillion text-white"
                      : "border border-ink/15 bg-transparent text-ink",
                  ]}
                >
                  COMEÇAR AGORA
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .pricing-acc.active {
    background: linear-gradient(145deg, rgba(242,237,228,0.95), rgba(242,237,228,0.85)) !important;
    border-color: rgba(242,237,228,0.3) !important;
  }
  .pricing-acc.active .pricing-acc-name {
    color: #070304;
    opacity: 1;
    font-size: 28px;
  }
  .pricing-acc.active .pricing-acc-price {
    color: #FF4401;
    opacity: 1;
    font-size: 28px;
  }
  .pricing-acc.active .pricing-acc-body {
    max-height: 600px !important;
    opacity: 1 !important;
  }
  .pricing-acc.past {
    background: rgba(242,237,228,0.04) !important;
  }
  .pricing-acc.past .pricing-acc-name {
    color: rgba(242,237,228,0.25);
  }
  .pricing-acc.past .pricing-acc-price {
    color: rgba(242,237,228,0.12);
  }
</style>

<script>
  function initPricing(): void {
    const runway = document.getElementById('pricing-reveal-runway');
    const label = document.getElementById('pricing-label');
    const wordEls = document.querySelectorAll<HTMLElement>('.pricing-word');
    const cardsSection = document.getElementById('pricing-cards-section');
    const cards = document.querySelectorAll<HTMLElement>('.pricing-acc');

    if (!runway || !label || !wordEls.length || !cardsSection || !cards.length) return;

    const wordCount = wordEls.length;
    const vh = window.innerHeight;

    // Set runway height for the title reveal scroll
    runway.style.height = `${vh * 2.2}px`;

    function onScroll(): void {
      // === Phase 1: Title word reveal ===
      const runwayRect = runway!.getBoundingClientRect();
      const revealScrolled = Math.max(0, -runwayRect.top);
      const revealTotal = runway!.offsetHeight - window.innerHeight;
      const rp = Math.min(1, revealScrolled / revealTotal);

      // Label fades in first
      label!.style.opacity = String(Math.min(1, rp * 3));

      // Words reveal staggered
      wordEls.forEach((el, i) => {
        const ws = (i + 0.1) / (wordCount + 0.3);
        const we = (i + 0.9) / (wordCount + 0.3);
        const wp = Math.max(0, Math.min(1, (rp - ws) / (we - ws)));
        const eased = 1 - Math.pow(1 - wp, 3);

        el.style.opacity = String(0.06 + eased * 0.94);
        el.style.filter = `blur(${6 * (1 - eased)}px)`;
      });

      // === Phase 2: Cards section appears after title fully revealed ===
      const cardsSectionRect = cardsSection!.getBoundingClientRect();
      const cardsVisible = cardsSectionRect.top < window.innerHeight * 0.8;

      if (cardsVisible) {
        cardsSection!.style.opacity = '1';
        cardsSection!.style.transform = 'translateY(0)';
      }

      // === Card accordion — one active at a time ===
      const triggerPoint = window.innerHeight * 0.55;
      let activeIndex = -1;

      cards.forEach((card, i) => {
        const cardRect = card.getBoundingClientRect();
        if (cardRect.top < triggerPoint) {
          activeIndex = i;
        }
      });

      cards.forEach((card, i) => {
        card.classList.remove('active', 'past');
        if (i === activeIndex) {
          card.classList.add('active');
        } else if (i < activeIndex) {
          card.classList.add('past');
        }
      });
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', () => {
      runway!.style.height = `${window.innerHeight * 2.2}px`;
    }, { passive: true });
    onScroll();
  }

  initPricing();
  document.addEventListener('astro:after-swap', initPricing);
</script>
