---
import { PROJECTS } from "../../data/projects";
---

<section id="trabalhos" class="relative bg-ink py-20">
  <!-- Section header -->
  <div class="mx-auto mb-16 max-w-site px-6 md:px-10" data-fade-up>
    <div class="flex items-end justify-between">
      <div>
        <span class="font-mono text-2xs tracking-caps text-vermillion">
          [TRABALHOS SELECIONADOS]
        </span>
        <h2 class="mt-2 font-display text-section-title tracking-snug text-cream">
          FEATURED <span class="text-vermillion">WORKS</span>
        </h2>
      </div>
      <span class="hidden font-mono text-xs text-cream-ghost md:block">
        006 projetos
      </span>
    </div>
  </div>

  <!-- Project rows -->
  <div class="mx-auto max-w-site px-6 md:px-10">
    {PROJECTS.map((project, i) => (
      <div
        class="project-row cursor-pointer"
        data-fade-up
        data-delay={String(Math.min(i + 1, 5))}
      >
        <div class="project-border relative border-t py-8">
          <!-- Hover glow -->
          <div class="project-glow pointer-events-none absolute inset-0" />

          <div class="relative grid items-center gap-5" style="grid-template-columns: 70px 1fr 180px 100px;">
            <!-- Tag -->
            <span class="project-tag font-mono text-2xs tracking-wide">
              [{project.tag}]
            </span>

            <!-- Title + category -->
            <div class="flex items-baseline gap-5">
              <h3 class="project-title font-display text-project-title tracking-snug">
                {project.title}
              </h3>
              <span class="hidden font-mono text-2xs tracking-wider md:inline" style="color: rgba(242,237,228,0.2);">
                [{project.cat}]
              </span>
            </div>

            <!-- Result -->
            <span class="project-result hidden text-right font-mono text-sm tracking-wide md:block">
              {project.result}
            </span>

            <!-- Arrow -->
            <div class="project-arrow text-right font-display text-xl text-vermillion">
              →
            </div>
          </div>

          <!-- Description on hover -->
          <div class="project-desc pl-0 md:pl-[90px]">
            <p class="max-w-[500px] pt-3 font-mono text-sm leading-relaxed" style="color: rgba(242,237,228,0.35);">
              {project.desc}
            </p>
          </div>
        </div>
      </div>
    ))}
    <!-- Bottom border -->
    <div class="border-t border-cream-ghost" />
  </div>
</section>
