---
import MatrixBG from "./MatrixBG.astro";
---

<section
  id="hero-section"
  class="relative bg-ink"
>
  <!--
    Two-phase hero:
    Phase 1: "Gladius Digital" fills the screen, shrinks on scroll
    Phase 2: After brand shrinks, "CRIAMOS SITES QUE VENDEM" fades in
  -->

  <!-- Scroll runway for the brand shrink + tagline reveal -->
  <div id="hero-runway" class="relative">
    <div class="sticky top-0 h-screen overflow-hidden">
      <MatrixBG opacity={0.06} />

      <!-- Brand mark — starts huge, shrinks on scroll -->
      <div
        id="hero-brand"
        class="absolute inset-0 z-[2] flex items-center justify-center"
        style="will-change: transform;"
      >
        <div class="text-center">
          <span
            id="hero-gladius"
            class="block font-brand italic text-cream"
            style="font-size: clamp(60px, 14vw, 160px); letter-spacing: 0.02em; line-height: 1; will-change: transform, font-size;"
          >
            Gladius
          </span>
          <span
            id="hero-digital"
            class="mt-2 block font-display tracking-mega text-cream/40"
            style="font-size: clamp(16px, 3vw, 36px); will-change: opacity;"
          >
            DIGITAL
          </span>
        </div>
      </div>

      <!-- Main tagline — hidden initially, fades in after brand shrinks -->
      <div
        id="hero-tagline"
        class="absolute inset-0 z-[2] flex flex-col items-center justify-center px-6 md:px-10"
        style="opacity: 0; will-change: opacity;"
      >
        <!-- Brand small (destination after shrink) -->
        <div id="hero-brand-small" class="mb-6 text-center" style="opacity: 0;">
          <span class="font-brand italic text-cream" style="font-size: clamp(32px, 3.5vw, 52px); letter-spacing: 0.02em; line-height: 1;">
            Gladius
          </span>
          <span class="ml-3 align-middle font-display tracking-mega text-cream/40" style="font-size: clamp(12px, 1.2vw, 18px);">
            DIGITAL
          </span>
        </div>

        <!-- CRIAMOS -->
        <div class="relative z-[2] text-center">
          <div
            class="font-display text-hero font-normal tracking-tight text-vermillion hero-word"
            style="opacity: 0; transform: translateY(30px);"
            data-word="0"
          >
            CRIAMOS
          </div>

          <!-- SITES [2026] QUE -->
          <div class="flex items-baseline justify-center" style="gap: clamp(12px, 2vw, 24px);">
            <span
              class="font-display text-hero font-normal tracking-tight text-vermillion hero-word"
              style="opacity: 0; transform: translateY(30px);"
              data-word="1"
            >
              SITES
            </span>
            <span
              class="whitespace-nowrap font-mono text-cream-ghost hero-word"
              style="font-size: clamp(11px, 1.2vw, 16px); opacity: 0;"
              data-word="4"
            >
              [2026]
            </span>
            <span
              class="font-display text-hero font-normal tracking-tight text-cream hero-word"
              style="opacity: 0; transform: translateY(30px);"
              data-word="2"
            >
              QUE
            </span>
          </div>

          <!-- VENDEM [POR VOCÊ] -->
          <div
            class="flex items-baseline justify-center font-display text-hero font-normal tracking-tight text-vermillion hero-word"
            style="gap: clamp(12px, 2vw, 24px); opacity: 0; transform: translateY(30px);"
            data-word="3"
          >
            VENDEM
            <span class="font-mono text-cream-ghost" style="font-size: clamp(11px, 1.2vw, 16px);">
              [POR VOCÊ]
            </span>
          </div>
        </div>
      </div>

      <!-- Bottom left CTA -->
      <a
        href="#contato"
        id="hero-cta"
        class="nav-link absolute bottom-10 left-6 z-[2] font-mono text-sm tracking-wider text-cream no-underline opacity-0 hover:text-vermillion hover:opacity-100 md:left-10"
      >
        [Iniciar um projeto]
      </a>

      <!-- Bottom right scroll indicator -->
      <div
        id="hero-scroll-hint"
        class="absolute bottom-10 right-6 z-[2] text-right md:right-10"
        style="opacity: 0;"
      >
        <div class="mb-1.5 font-mono text-2xs tracking-widest text-cream">
          [SCROLL]
        </div>
        <div class="mb-1 font-script text-base text-vermillion">
          Por aqui
        </div>
        <div class="flex items-center justify-end gap-2">
          <span class="font-mono text-xs text-cream-fade">
            Para ver nosso trabalho.
          </span>
          <div class="h-px w-10 bg-vermillion"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  function initHero(): void {
    const runway = document.getElementById('hero-runway');
    const brand = document.getElementById('hero-brand');
    const gladius = document.getElementById('hero-gladius');
    const digital = document.getElementById('hero-digital');
    const tagline = document.getElementById('hero-tagline');
    const brandSmall = document.getElementById('hero-brand-small');
    const cta = document.getElementById('hero-cta');
    const scrollHint = document.getElementById('hero-scroll-hint');
    const heroWords = document.querySelectorAll<HTMLElement>('.hero-word');

    if (!runway || !brand || !gladius || !digital || !tagline || !brandSmall || !cta || !scrollHint) return;

    const vh = window.innerHeight;
    // Phase 1: brand shrink (1.5vh), Phase 2: tagline reveal (1.5vh)
    runway.style.height = `${vh * 3.5}px`;

    function onScroll(): void {
      const rect = runway!.getBoundingClientRect();
      const scrolled = Math.max(0, -rect.top);
      const totalScroll = runway!.offsetHeight - window.innerHeight;
      const progress = scrolled / totalScroll;

      // === Phase 1 (0 – 0.4): Brand shrinks ===
      const phase1End = 0.4;
      const p1 = Math.min(1, progress / phase1End);
      const shrinkEased = 1 - Math.pow(1 - p1, 2);

      // Scale from 1.0 → 0.35
      const brandScale = 1 - shrinkEased * 0.65;
      // Move up slightly
      const brandY = -shrinkEased * 15;

      brand!.style.transform = `scale(${brandScale}) translateY(${brandY}%)`;
      brand!.style.opacity = String(1 - shrinkEased);

      // "DIGITAL" fades out faster
      digital!.style.opacity = String(Math.max(0, 1 - p1 * 2.5));

      // === Phase 2 (0.35 – 1.0): Tagline appears ===
      const phase2Start = 0.35;
      const p2 = Math.max(0, Math.min(1, (progress - phase2Start) / (1 - phase2Start)));

      // Show tagline container
      tagline!.style.opacity = String(Math.min(1, p2 * 2));

      // Small brand appears
      brandSmall!.style.opacity = String(Math.min(1, p2 * 3));

      // Words reveal staggered
      heroWords.forEach((el) => {
        const wordIndex = Number(el.dataset.word);
        const wordStart = 0.1 + wordIndex * 0.12;
        const wp = Math.max(0, Math.min(1, (p2 - wordStart) / 0.2));
        const eased = 1 - Math.pow(1 - wp, 3);

        el.style.opacity = String(eased);
        el.style.transform = `translateY(${30 * (1 - eased)}px)`;
      });

      // CTA + scroll hint appear at end
      const uiAppear = Math.max(0, Math.min(1, (p2 - 0.7) / 0.3));
      cta!.style.opacity = String(uiAppear * 0.5);
      scrollHint!.style.opacity = String(uiAppear * 0.4);
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', () => {
      runway!.style.height = `${window.innerHeight * 3.5}px`;
    }, { passive: true });
    onScroll();
  }

  initHero();
  document.addEventListener('astro:after-swap', initHero);
</script>
